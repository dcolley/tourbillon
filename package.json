{
  "name": "tourbillon",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI agent orchestration — Mastra.ai + LM Studio + shadcn/ui",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "db:generate": "pnpm --filter @tourbillon/db generate",
    "db:migrate": "pnpm --filter @tourbillon/db migrate",
    "db:studio": "pnpm --filter @tourbillon/db studio",
    "workers:dev": "pnpm --filter @tourbillon/scheduler dev",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "deps:check": "pnpm outdated -r",
    "deps:update:safe": "pnpm up -r"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "prettier": "catalog:",
    "eslint": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
