{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@paperclip-mastra/db": ["../../packages/db/src/index.ts"],
      "@paperclip-mastra/shared": ["../../packages/shared/src/index.ts"],
      "@paperclip-mastra/mastra": ["../../packages/mastra/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
