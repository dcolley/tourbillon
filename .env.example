# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paperclip_mastra
# Max connections per app process (postgres.js pool). Keep low in dev — scheduler + web each open a pool.
DATABASE_POOL_MAX=5

# LLM provider (lmstudio | ollama | openai-compatible)
LLM_PROVIDER=lmstudio
# chat = /v1/chat/completions, responses = OpenAI /v1/responses API
LLM_API_MODE=chat
# Optional unified overrides (used when provider-specific vars are unset)
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_DEFAULT_MODEL=

# LM Studio (local OpenAI-compatible API)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# OLLAMA_DEFAULT_MODEL=llama3.2

# Per-agent overrides (agents.adapter_config JSON):
# { "provider": "ollama", "apiMode": "chat", "baseURL": "http://localhost:11434/v1" }

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Internal API (used by workers to call the Next.js API routes)
INTERNAL_API_URL=http://localhost:3002

# Scheduler service key (routine-scheduler → POST /api/companies/:id/issues)
SCHEDULER_API_KEY=change-me-in-production

# Optional: Tavily web search (cloud fallback)
# TAVILY_API_KEY=

# Optional: SearXNG local web search
# SEARXNG_URL=http://localhost:8888

# Optional: Mastra semantic memory recall (cross-issue patterns within goal/project scope)
# Requires an embedding model available via LM Studio or your OpenAI-compatible endpoint.
# MEMORY_SEMANTIC_RECALL=true
# MEMORY_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
